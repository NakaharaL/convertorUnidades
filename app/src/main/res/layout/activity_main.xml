<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 1) CABEÇALHO CORRIGIDO CONTRA SOBREPOSIÇÃO -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/btnSobre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sobre"
            android:textColor="#0000EE"
            android:textSize="16sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/conversor_de_unidades"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btnSobre"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- 2) CATEGORIAS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">

        <RadioGroup
            android:id="@+id/rgTiposUnidades"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbComprimento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/comprimento"
                android:checked="true"
                android:layout_marginEnd="8dp"/>

            <RadioButton
                android:id="@+id/rbVelocidade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/velocidade"
                android:layout_marginEnd="8dp"/>

            <RadioButton
                android:id="@+id/rbTemperatura"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/temperatura" />

            <RadioButton
                android:id="@+id/rbVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/volume"
                android:layout_marginEnd="8dp"/>

            <RadioButton
                android:id="@+id/rbPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/peso" />
        </RadioGroup>
    </HorizontalScrollView>

    <!-- 3) ENTRADA 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/etValorEntrada"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:hint="@string/digite_o_valor"
            android:inputType="numberDecimal"
            android:importantForAutofill="no" />

        <Spinner
            android:id="@+id/spUnidadeEntrada"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- 4) ALTERNAR -->
    <Button
        android:id="@+id/btnAlternar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/alternarUnidades"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- 5) ENTRADA 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etValorSaida"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:hint="@string/resultado"
            android:inputType="numberDecimal"
            android:importantForAutofill="no" />

        <Spinner
            android:id="@+id/spUnidadeSaida"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- 6) AÇÕES (ESTILOS PADRONIZADOS) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        style="?android:attr/buttonBarStyle"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnLimpar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/limpar"
            android:layout_marginEnd="8dp"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnConverter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/converter"
            android:layout_marginStart="8dp"
            style="?android:attr/buttonBarButtonStyle" />

    </LinearLayout>

    <!-- 7) CABEÇALHO HISTÓRICO CORRIGIDO CONTRA SOBREPOSIÇÃO -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnLimparHistorico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/limpar_historico"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#FF0000"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/tvTituloHistorico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/historico_de_conversoes"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btnLimparHistorico"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- 8) LISTA HISTÓRICO -->
    <ListView
        android:id="@+id/lvHistorico"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:entries="@array/dados_fake_historico"
        android:listSelector="@android:color/transparent"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp" />

</LinearLayout>